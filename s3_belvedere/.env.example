# Garage S3 Storage Configuration
GARAGE_S3_PORT=3900
GARAGE_RPC_PORT=3901
GARAGE_ADMIN_PORT=3903
GARAGE_METRICS_PORT=3904
GARAGE_UI_PORT=3905

# Garage Security Tokens (CHANGE THESE IN PRODUCTION)
GARAGE_RPC_SECRET=insecure_dev_secret_change_me_in_production
GARAGE_ADMIN_TOKEN=dev_admin_token_change_me_in_production

# Backend Storage Configuration (for backend .env)
Storage__ServiceUrl=http://garage:3900
Storage__BucketName=belvedere
Storage__AccessKey=belvedere_access_key
Storage__SecretKey=belvedere_secret_key
Storage__Region=us-east-1
Storage__ForcePathStyle=true

