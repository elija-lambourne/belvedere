# Keycloak Configuration Example
# Copy this file to .env and customize as needed
# This file contains common configuration options

# ============================================================================
# ADMIN CREDENTIALS
# ============================================================================
# These are the initial admin credentials for accessing the Keycloak admin console

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_password

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection settings (for the postgres service)

POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=keycloak_password

# Keycloak runtime DB settings (Keycloak will default to use POSTGRES_* credentials)
KC_DB=postgres
# Optional override for JDBC URL
# KC_DB_URL=jdbc:postgresql://postgres:5432/${POSTGRES_DB}


# ============================================================================
# HTTP/HTTPS CONFIGURATION
# ============================================================================

# Enable HTTP (for development only)
KC_HTTP_ENABLED=true

# Proxy settings (use 'edge' when behind a reverse proxy)
KC_PROXY=edge

# ============================================================================
# HOSTNAME CONFIGURATION
# ============================================================================
# These settings determine the public URL Keycloak uses

KC_HOSTNAME=localhost
KC_HOSTNAME_PORT=8080
KC_HOSTNAME_STRICT=false
KC_HOSTNAME_STRICT_HTTPS=false

# ============================================================================
# OPTIONAL: PRODUCTION SETTINGS
# ============================================================================
# Uncomment and configure these for production use

# Enable HTTPS strict mode (requires valid certificate)
# KC_HOSTNAME_STRICT_HTTPS=true

# Use HTTPS for all redirects
# KC_HTTP_ENABLED=false

# Require HTTPS for external communication
# KC_HTTPS_PORT=8443
# KC_HTTPS_KEY_STORE_FILE=/etc/keycloak/keystore.jks
# KC_HTTPS_KEY_STORE_PASSWORD=your_keystore_password
# KC_HTTPS_KEY_STORE_TYPE=JKS

# ============================================================================
# OPTIONAL: MAIL/SMTP CONFIGURATION
# ============================================================================
# Configure email settings for sending notifications

# KC_MAIL_HOST=smtp.example.com
# KC_MAIL_PORT=587
# KC_MAIL_USERNAME=your-email@example.com
# KC_MAIL_PASSWORD=your-password
# KC_MAIL_FROM=noreply@example.com
# KC_MAIL_SSL=true
# KC_MAIL_STARTTLS=true

# ============================================================================
# OPTIONAL: LOGGING CONFIGURATION
# ============================================================================
# Configure logging levels

# KC_LOG_LEVEL=INFO
# KC_LOG_FILE=/opt/keycloak/data/logs/keycloak.log

# ============================================================================
# OPTIONAL: CACHE CONFIGURATION
# ============================================================================

# KC_CACHE=ispn
# KC_CACHE_CONFIG_FILE=cache-ispn-local.xml

# ============================================================================
# OPTIONAL: FEATURES (if enabled in your Keycloak version)
# ============================================================================

# KC_FEATURES=account3,admin_fine_grained_authz,scripts,docker

# ============================================================================
# OPTIONAL: METRICS
# ============================================================================

# KC_METRICS_ENABLED=true

